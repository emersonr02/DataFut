@model DataFut.Models.Entities.Clube

@{
    ViewData["Title"] = "Eliminar Clube";
}

<h1>Eliminar Clube</h1>
<p class="text-danger">Tens a certeza que queres eliminar este clube?</p>

<dl class="row">
    <dt class="col-sm-2">Nome</dt>
    <dd class="col-sm-10">@Model.Nome</dd>

    <dt class="col-sm-2">Cidade</dt>
    <dd class="col-sm-10">@Model.Cidade</dd>

    <dt class="col-sm-2">Jogadores</dt>
    <dd class="col-sm-10">@Model.Jogadores?.Count (ficarão sem clube)</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar Eliminação</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>