@model DataFut.Models.Entities.Posicao

@{
    ViewData["Title"] = "Eliminar Posição";
}

<h1>Eliminar Posição</h1>
<p class="text-danger">Tens a certeza que queres eliminar esta posição?</p>

<dl class="row">
    <dt class="col-sm-2">Nome</dt>
    <dd class="col-sm-10">@Model.Nome</dd>

    <dt class="col-sm-2">Jogadores associados</dt>
    <dd class="col-sm-10">@(Model.Jogadores?.Count ?? 0)</dd>
</dl>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar Eliminação</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>