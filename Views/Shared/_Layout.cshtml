<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DataFut</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Roboto:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="d-flex vh-100">

        <div class="d-flex flex-column flex-shrink-0 p-3 text-white shadow" style="width: 260px; background-color: #1A237E; z-index: 1000;">
            <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
                <i class="fas fa-shield-alt fa-2x me-3" style="color: #FFD600;"></i>
                <span class="fs-4 fw-bold font-montserrat">DataFut</span>
            </a>
            <hr>
            
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index" class="nav-link">
                        <i class="fas fa-chart-line me-2"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a asp-controller="Clubes" asp-action="Index" class="nav-link">
                        <i class="fas fa-shield-alt me-2"></i> Clubes
                    </a>
                </li>
                <li>
                    <a asp-controller="Jogadores" asp-action="Index" class="nav-link">
                        <i class="fas fa-running me-2"></i> Jogadores
                    </a>
                </li>
                @if (User.IsInRole("Gestor de Clube"))
                {
                    <li>
                        <a asp-controller="Jogadores" asp-action="Contratar" class="nav-link">
                            <i class="fas fa-file-signature me-2"></i> Nova Contratação
                        </a>
                    </li>
                }
            </ul>
            <hr>
            
            <div class="small text-center text-white-50">
                &copy; 2026 - Projeto UC00608
            </div>
        </div>

        <div class="d-flex flex-column flex-grow-1 overflow-auto" style="background-color: #F4F7F6;">
            
            <header class="p-3 mb-4 bg-white border-bottom shadow-sm">
                <div class="container-fluid d-flex justify-content-end align-items-center">
                    <partial name="_LoginPartial" />
                </div>
            </header>

            <main class="container-fluid px-4 pb-4">
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>