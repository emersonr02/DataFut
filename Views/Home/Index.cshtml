@{
    ViewData["Title"] = "Dashboard";
}

<div class="text-center mt-5 mb-5">
    <h1 class="display-4">Bem-vindo ao DataFut</h1>
    <p class="lead text-muted">A sua plataforma central de gestão de transferências de futebol.</p>
    <hr class="my-4" style="width: 100px; border-top: 3px solid #FFD600; margin: 0 auto;">
</div>

<div class="row mt-4">
    <div class="col-md-4 mb-4">
        <div class="card card-futebol h-100 p-3 text-center">
            <div class="card-body">
                <i class="fas fa-shield-alt fa-3x mb-3" style="color: #1A237E;"></i>
                <h5 class="card-title text-muted">Total Clubes</h5>
                <p class="display-5 fw-bold">24</p>
                <a href="#" class="btn btn-sm btn-outline-primary mt-2">Gerir Clubes</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card card-futebol h-100 p-3 text-center">
            <div class="card-body">
                <i class="fas fa-users fa-3x mb-3" style="color: #1A237E;"></i>
                <h5 class="card-title text-muted">Total Jogadores</h5>
                <p class="display-5 fw-bold">512</p>
                <a href="#" class="btn btn-sm btn-outline-primary mt-2">Ver Jogadores</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card card-futebol h-100 p-3 text-center">
            <div class="card-body">
                <i class="fas fa-file-contract fa-3x mb-3" style="color: #FFD600;"></i>
                <h5 class="card-title text-muted">Total Contratações</h5>
                <p class="display-5 fw-bold">3</p>
                <div class="mt-auto">
                    <a asp-controller="Jogadores" asp-action="Create" class="btn btn-sm btn-outline-primary mt-2">
                        Registar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card card-futebol p-4 mt-4 mb-5">
    <h3 class="mb-3">Últimas Transferências</h3>
    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Data</th>
                    <th>Jogador</th>
                    <th>Clube Origem</th>
                    <th>Clube Destino</th>
                    <th>Valor</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>15/04/2026</td>
                    <td>João Silva</td>
                    <td>SL Benfica</td>
                    <td>FC Porto</td>
                    <td>€ 15M</td>
                </tr>
                <tr>
                    <td>12/04/2026</td>
                    <td>Carlos Pereira</td>
                    <td>Sporting CP</td>
                    <td>Sp. Braga</td>
                    <td>€ 8M</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>