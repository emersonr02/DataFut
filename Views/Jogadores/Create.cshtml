@model DataFut.Models.Entities.Jogador

@{
    ViewData["Title"] = "Nova Contratação";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-stats shadow p-4" style="border-radius: 15px; background: white;">
                <div class="text-center mb-4">
                    <h2 class="fw-bold" style="color: #1A237E;">Registar Jogador</h2>
                    <div style="width: 50px; height: 3px; background: #FFD600; margin: 10px auto;"></div>
                </div>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nome" class="form-label fw-bold">Nome</label>
                            <input asp-for="Nome" class="form-control" placeholder="Primeiro Nome" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Apelido" class="form-label fw-bold">Apelido</label>
                            <input asp-for="Apelido" class="form-control" placeholder="Último Nome" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Clube de Destino</label>
                        <select asp-for="ClubeId" class="form-select">
                            <option value="">-- Selecione o Clube --</option>
                            <option value="1">SL Benfica</option>
                            <option value="2">FC Porto</option>
                            <option value="3">Sporting CP</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Posição</label>
                        <select name="posicoesSelecionadas" class="form-select" required>
                            <option value="">-- Selecione a Posição --</option>
                            <option value="1">Guarda-Redes</option>
                            <option value="2">Defesa</option>
                            <option value="3">Médio</option>
                            <option value="4">Avançado</option>
                        </select>
                        <small class="text-muted">O sistema impede mais de 5 jogadores por posição.</small>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a asp-action="Index" asp-controller="Home" class="text-muted text-decoration-none">
                            <i class="fas fa-arrow-left me-1"></i> Voltar
                        </a>
                        <button type="submit" class="btn btn-warning px-5 fw-bold" style="border-radius: 50px; color: #1A237E;">
                            Efetivar Contratação
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>